// Stock Analyzer Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Alert {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  symbol      String
  targetPrice Float
  type        String   @default("UPPER") // UPPER or LOWER
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brokerType      String?
  brokerApiKey    String?
  brokerApiSecret String?
  brokerAccess    String?

  watchlist Watchlist[]
  portfolio PortfolioItem[]
  alerts    Alert[]
  savedStrategies SavedStrategy[]
  queuedTrades    QueuedTrade[]
}

model QueuedTrade {
  id           String   @id @default(uuid())
  userId       String
  trades          Json     // Array of trades: { symbol, quantity, price, action }
  brokerApiKey    String?  // Optional: stored for background execution
  brokerApiSecret String?  // Optional: stored for background execution
  brokerType      String   @default("zerodha") // zerodha, groww
  status          String   @default("PENDING") // PENDING, EXECUTED, FAILED
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model Stock {
  id            String   @id @default(uuid())
  symbol        String   @unique // e.g., RELIANCE.NS, TCS.NS
  name          String?
  sector        String?
  industry      String?
  
  history       StockHistory[]
  news          News[]
  watchlists    Watchlist[]
  portfolioItems PortfolioItem[]
  
  updatedAt     DateTime @updatedAt
}

model StockHistory {
  id        String   @id @default(uuid())
  stockId   String
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    BigInt
  
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
}

model News {
  id            String   @id @default(uuid())
  stockId       String?
  title         String
  description   String?
  url           String   @unique
  source        String?
  publishedAt   DateTime
  sentiment     Float?   // -1 to 1
  impactScore   Float?   // 0 to 1
  
  stock         Stock?   @relation(fields: [stockId], references: [id])
  createdAt     DateTime @default(now())
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  stockId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
}

model PortfolioItem {
  id          String   @id @default(uuid())
  userId      String
  stockId     String
  quantity    Float    @default(0)
  avgPrice    Float    @default(0) // The price at which it was bought
  totalCost   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock       Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
}

model SavedStrategy {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  data        Json    // Store the strategy object
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

